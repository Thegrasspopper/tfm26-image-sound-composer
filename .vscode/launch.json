{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "justMyCode": false,
    "breakOnLoad": true,
    "configurations": [
        {
            "type": "node-terminal",
            "name": "Run Script: build",
            "request": "launch",
            "command": "npm run build",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "node-terminal",
            "name": "Run Script: dev with debug",
            "request": "launch",
            "serverReadyAction": {
                "pattern": "localhost:(\\d+)",
                "uriFormat": "http://localhost:%s",
                "action": "debugWithEdge"
            },
            "command": "npm run dev",
            "sourceMaps": true,
            "cwd": "${workspaceFolder}",
        }
    ]
}